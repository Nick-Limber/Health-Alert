<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- When Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1E4E87"/>       <!-- Dark Blue inside button when pressed -->
            <stroke android:width="2dp"
                android:color="#26A69A"/>      <!-- Teal border stays when presses-->
            <corners android:radius="26dp"/>       <!-- Rounded corners -->
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#26A69A"/>       <!-- Teal color inside button-->
            <stroke android:width="2dp"
                android:color="#26A69A"/> <!-- Teal border on button-->
            <corners android:radius="26dp"/>
        </shape>
    </item>


</selector>