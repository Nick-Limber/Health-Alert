<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginTop="10dp">

    <!-- Post Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Title"
        android:textStyle="bold"
        android:textSize="16sp"/>

    <!-- Post Content -->
    <TextView
        android:id="@+id/tvContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTitle"
        android:text="Content"
        android:textSize="14sp"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvUsername"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvContent"
        android:text="By: User"
        android:textStyle="italic"
        android:textColor="#555555"
        android:textSize="12sp"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvUsername"
        android:text="Timestamp"
        android:textSize="12sp"
        android:layout_marginTop="4dp"/>


    <!--Delete Button-->
    <ImageButton
        android:id="@+id/btnDelete"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="@null"
        android:layout_alignParentEnd="true"
        android:layout_margin="8dp"
        android:contentDescription="Delete Post"/>


    <!-- Show/Hide Replies Button -->
    <Button
        android:id="@+id/btnShowReplies"
        android:layout_below="@id/tvTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Show Replies"
        android:layout_marginTop="4dp"/>


    <!-- Replies Layout -->
    <LinearLayout
        android:id="@+id/repliesLayout"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnShowReplies"
        android:layout_marginTop="8dp"/>


    <!-- Reply Button -->
    <Button
        android:id="@+id/btnReply"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reply"
        android:layout_below="@id/repliesLayout"
        android:layout_marginTop="4dp"/>


</RelativeLayout>